# ---- Mobile (Expo) ----
# Эти переменные читаются на этапе сборки (EXPO_PUBLIC_*).
# Можно вместо них править app.json -> expo.extra.

# Адрес API. На РЕАЛЬНОМ устройстве/эмуляторе localhost не работает —
# подставьте IP вашей машины, напр. http://192.168.1.10:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# WebSocket (по умолчанию = API_URL)
EXPO_PUBLIC_WS_URL=http://localhost:4000

# Карты: google | 2gis | yandex
EXPO_PUBLIC_MAP_PROVIDER=google

# Ключ карт (для 2ГИС/Яндекс/Google web). Для Google на Android ключ также
# нужно прописать в app.json -> android.config.googleMaps.apiKey
EXPO_PUBLIC_MAP_API_KEY=
