# ---- Backend (.env) ----
NODE_ENV=development
PORT=4000

# PostgreSQL (локально или Railway). Пример локально:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/obi?schema=public"

# JWT — СГЕНЕРИРУЙТЕ длинные случайные строки (например: openssl rand -hex 32)
JWT_ACCESS_SECRET="change_me_access_secret_min_16_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_16_chars"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS: список origin через запятую, либо * для разработки
CORS_ORIGINS=*

# Секретный код для регистрации администратора через приложение.
# Если пусто — стать админом через регистрацию нельзя. Задайте свой.
ADMIN_REGISTER_CODE=change_me_admin_code

# Публичный URL самого бэкенда (для локального хранилища фото).
# На реальном устройстве замените localhost на IP вашего ПК.
BACKEND_PUBLIC_URL=http://localhost:4000

# SMS-провайдер: dev (код печатается в лог, в dev всегда 0000) | osonsms | twilio
SMS_PROVIDER=dev
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER=

# Хранилище файлов: local | s3 (R2 — это s3-совместимый)
STORAGE_PROVIDER=local
# Для s3/R2:
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
